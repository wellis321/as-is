# Copy this file to .env and fill in your values.
# cp .env.example .env

# --- App ---
APP_ENV=local
APP_URL=http://localhost:8890
SESSION_SECRET=change_this_secret_in_production

# --- Local MAMP ---
DB_HOST=127.0.0.1
DB_PORT=8889
DB_DATABASE=as_is
DB_USERNAME=root
DB_PASSWORD=root
DB_CHARSET=utf8mb4

# Bootstrap admin user (created on first request if users table is empty)
ADMIN_USER=admin
ADMIN_PASS=admin

# --- Hostinger (hPanel → Databases) ---
# APP_ENV=production
# APP_URL=https://yourdomain.com
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=u123456789_as_is
# DB_USERNAME=u123456789_as_is
# DB_PASSWORD=your_database_password
# DB_CHARSET=utf8mb4
# ADMIN_USER=admin
# ADMIN_PASS=your_strong_admin_password
# SESSION_SECRET=a_long_random_string_for_production

# --- Microsoft Entra ID (optional SSO) ---
# Requires: composer install
# ENTRA_ENABLED=false
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
# ENTRA_REDIRECT_URI=          # optional; default APP_URL/auth/microsoft/callback.php
# ENTRA_ALLOWED_ROLES=SOR.Admin,SOR.Editor,SOR.Viewer
