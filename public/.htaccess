DirectoryIndex index.php

Options -Indexes

# Prevent indexing at the HTTP level — belt-and-braces with the PHP header
<IfModule mod_headers.c>
    Header always set X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"
</IfModule>

# Block direct access to SQL dumps if ever copied here by mistake
<FilesMatch "\.(sql|md|example)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>
